"VertexLitGeneric"
{
    "$basetexture" "pwci\mw\attachments\att_lens_holo_rgb"
    "$bumpmap" "pwci\mw\attachments\att_lens_holo_n"
    "$phongexponenttexture" "pwci\mw\attachments\att_lens_holo_e"

    /////////////////
    "$color2" "[1 1 1]"                                     //do not touch this
    "$translucent" "1"                             //do not touch this
    /////////////////

    "$phong" "1"
    "$phongboost" "0.02"
    "$phongalbedotint" "1"
    "$phongalbedoboost" "20"                                //toy around with this
    "$phongfresnelranges" "[1 0.1 0]"

    //rimlight doesn't properly show in hlmv, make sure you're changing these values in game
    "$rimlight" "1"
    "$rimlightexponent" "100"
    "$rimmask" "1"
    "$rimlightboost" "1"
       
    /////////////////
    "$normalmapalphaenvmapmask" "1"                         //do not touch this
    /////////////////

    "$envmap" "pwci\mw\weapons\shared\specularity_100"
    "$envmaptint" "[0.098 0.098 0.098]"                 

    //remove this if not using MWB
    "Proxies"
    {
        "MwEnvMapTint"
        {
            "min" "0"
            "max" "0.4"
            "envmap" "pwci\mw\weapons\shared\specularity_100"
            "color" "[0.01 0.01 0.01]"
        }
    }
}

