"VertexlitGeneric"
{
    "$basetexture" "pwci\mw\attachments\att_lens_onex_opaque_rgb"
	"$bumpmap"				"viper/MW/attachments/holo_east_lens_n" 
    "$phongexponenttexture" "pwci\mw\attachments\att_lens_onex_opaque_e"
	
	$phong	"1"
	$phongboost	"0.5"
	$phongexponent	"30"
	$phongfresnelranges	"[1 0.5 0]"

	$envmap	"env_cubemap"
	$envmaptint	"[.5 .5 .5]"
	$normalmapalphaenvmapmask	"1"
	$envmapfresnel	"5"

	$rimlight	"1"
	$rimmask	"1"
	$rimlightboost	"1"
	$rimlightexponent	"100"
}

